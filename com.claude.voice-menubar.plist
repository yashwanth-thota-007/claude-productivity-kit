<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude.voice-menubar</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3.13</string>
        <string>CLAUDE_HOME/.claude/scripts/voice-menubar.py</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>CLAUDE_HOME</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/usr/sbin:/bin:/sbin</string>
        <key>AWS_PROFILE</key>
        <string>YOUR_AWS_PROFILE</string>
        <key>AWS_REGION</key>
        <string>us-east-1</string>
        <key>CLAUDE_CODE_USE_BEDROCK</key>
        <string>1</string>
        <key>ANTHROPIC_MODEL</key>
        <string>YOUR_SONNET_MODEL_ID</string>
        <key>ANTHROPIC_SMALL_FAST_MODEL</key>
        <string>YOUR_HAIKU_MODEL_ID</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/voice-menubar.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/voice-menubar.log</string>
</dict>
</plist>
